DATABASE_URL=postgres://supplier_sync:supplier_sync@localhost:5432/supplier_sync
REDIS_URL=redis://localhost:6379
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
CJ_ACCOUNT_ID=
CJ_ACCOUNT_NAME=default
# Preferred: set CJ_API_KEY and run pnpm cj:auth:token to fetch/store tokens.
CJ_API_KEY=
CJ_ACCESS_TOKEN=
CJ_REFRESH_TOKEN=
# Old accounts registered before 2026-06-01 stay on QPS limits until 2026-07-01.
CJ_REGISTERED_AT=2026-05-31T00:00:00.000Z
CJ_ACCOUNT_QPS_LIMIT=1
CJ_SYNC_COUNTRY_MODE=none
CJ_SYNC_MIN_SELL_PRICE=0.01
CJ_SYNC_MAX_SELL_PRICE=
CJ_SYNC_MIN_WAREHOUSE_INVENTORY=1
CJ_SYNC_MAX_WAREHOUSE_INVENTORY=
CJ_SYNC_VERIFIED_WAREHOUSE=verified
CJ_SYNC_PRODUCT_FLAG=trending
CJ_SYNC_FREE_SHIPPING_ONLY=false
CJ_SYNC_TIME_START=2020-01-01T00:00:00.000Z
CJ_SYNC_TIME_END=
CJ_MAX_CONCURRENCY=4
CJ_IP_QPS_LIMIT=10
CJ_ADAPTIVE_COOLDOWN_MS=60000
CJ_ADAPTIVE_RECOVERY_SUCCESSES=120
